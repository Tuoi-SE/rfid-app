@startuml
title UC-001 - Khởi tạo tag và gán vào sản phẩm

left to right direction
skinparam shadowing false
skinparam actorStyle awesome
skinparam packageStyle rectangle

actor "Super Admin\n(`SUPER_ADMIN`)" as SA
actor "Admin\n(`ADMIN`)" as AD
actor "RFID Reader\nST-H103 UHF" as Reader

rectangle "RFID Tracking System" {
  usecase "UC-001\nKhởi tạo tag\nvà gán product" as Main
  usecase "Tạo tag trắng" as CreateTag
  usecase "Tra cứu sản phẩm" as LookupProduct
  usecase "Gán tag vào product" as AssignTag
  usecase "Kiểm tra EPC hợp lệ\nvà duy nhất" as ValidateEPC
  usecase "Auto-create EPC lạ\nqua scanStream" as AutoCreate
}

SA --> Main
AD --> Main
Reader --> AutoCreate

Main .> CreateTag : <<include>>
Main .> LookupProduct : <<include>>
Main .> AssignTag : <<include>>
CreateTag .> ValidateEPC : <<include>>
AutoCreate ..> Main : <<extend>>

note bottom of CreateTag
POST /api/tags
Policy: create Tag
end note

note bottom of AssignTag
PATCH /api/tags/assign
{ productId, tagIds[] }
end note

note bottom of AutoCreate
Gateway may auto-create unknown EPCs
as Tag with status UNASSIGNED.
end note

@enduml
