@startuml
title UC-002 - Dieu chuyen noi bo

top to bottom direction
skinparam shadowing false
skinparam actorStyle awesome
skinparam packageStyle rectangle

actor "Super Admin\n(`SUPER_ADMIN`)" as SA
actor "Warehouse Manager\n(`WAREHOUSE_MANAGER`)" as WM
actor "RFID Reader\nST-H103 UHF" as Reader

rectangle "RFID Tracking System" {
  usecase "UC-002\nDieu chuyen noi bo" as Main
  usecase "Tao transfer\nPENDING" as CreateTransfer
  usecase "Validate source /\ndestination theo type" as ValidateType
  usecase "Scan verify" as ScanVerify
  usecase "Confirm transfer" as ConfirmTransfer
  usecase "Danh dau tag thieu\nla MISSING" as MarkMissing
}

SA --> Main
WM --> Main
Reader --> ScanVerify

Main .> CreateTransfer : <<include>>
CreateTransfer .> ValidateType : <<include>>
Main .> ConfirmTransfer : <<include>>
ConfirmTransfer .> ScanVerify : <<include>>
ConfirmTransfer .> MarkMissing : <<include>>

note bottom of Main
UC-002 chi the hien operational workflow.
SUPER_ADMIN va WAREHOUSE_MANAGER
tao va confirm transfer noi bo.
end note

note bottom of ValidateType
ADMIN_TO_WORKSHOP:
ADMIN -> WORKSHOP

WORKSHOP_TO_WAREHOUSE:
WORKSHOP_WAREHOUSE -> WAREHOUSE
end note

@enduml
