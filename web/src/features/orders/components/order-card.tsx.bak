import React, { useState, useRef, useEffect } from 'react';
import { ArrowUpRight, ArrowDownLeft, Edit2, Trash2, Eye, MoreVertical } from 'lucide-react';
import { Order, OrderItem } from '../types';

interface OrderCardProps {
  order: Order;
  onView: (id: string) => void;
  onEdit: (id: string) => void;
  onDelete: (id: string) => void;
}

export const OrderCard = ({ order, onView, onEdit, onDelete }: OrderCardProps) => {
  const [isMenuOpen, setIsMenuOpen] = useState(false);
  const menuRef = useRef<HTMLDivElement>(null);

  useEffect(() => {
    const handleClickOutside = (event: MouseEvent) => {
      if (menuRef.current && !menuRef.current.contains(event.target as Node)) {
        setIsMenuOpen(false);
      }
    };
    if (isMenuOpen) document.addEventListener('mousedown', handleClickOutside);
    return () => document.removeEventListener('mousedown', handleClickOutside);
  }, [isMenuOpen]);

  const getProgress = (items: OrderItem[]) => {
    const totalReq = items.reduce((acc, curr) => acc + curr.quantity, 0);
    const totalScan = items.reduce((acc, curr) => acc + curr.scannedQuantity, 0);
    const pct = totalReq === 0 ? 0 : Math.round((totalScan / totalReq) * 100);
    return { scan: totalScan, req: totalReq, pending: totalReq - totalScan, pct };
  };

  const prog = getProgress(order.items);
  const isInbound = order.type === 'INBOUND';

  // Config mapping for styling based on status
  const statusConfig: Record<string, { label: string; colors: string; bar: string }> = {
    PENDING: { label: 'CHỜ XỬ LÝ', colors: 'bg-slate-100 text-slate-600', bar: 'bg-slate-200' },
    IN_PROGRESS: { label: 'ĐANG QUÉT', colors: 'bg-amber-100 text-amber-700', bar: 'bg-[#04147B]' },
    COMPLETED: { label: 'HOÀN THÀNH', colors: 'bg-emerald-100 text-emerald-700', bar: 'bg-emerald-500' },
    CANCELLED: { label: 'ĐÃ HỦY', colors: 'bg-red-100 text-red-700', bar: 'bg-red-400' },
  };

  const statusObj = statusConfig[order.status] || statusConfig.PENDING;

  const TypeIcon = isInbound ? ArrowDownLeft : ArrowUpRight;
  const typeIconBg = isInbound ? 'bg-indigo-50 border-indigo-100 text-[#04147B]' : 'bg-emerald-50 border-emerald-100 text-emerald-600';
  const typeBadgeColors = isInbound ? 'bg-indigo-50 text-[#04147B]' : 'bg-emerald-50 text-emerald-600';

  // Format Date (support both snake_case from backend API and camelCase from interface)
  const rawDate = (order as any).created_at || order.createdAt;
  const dateStr = rawDate ? new Date(rawDate).toLocaleString('vi-VN', {
    day: '2-digit', month: '2-digit', year: 'numeric',
    hour: '2-digit', minute: '2-digit'
  }) : '—';

  const creatorName = (order as any).created_by?.username || (order as any).createdBy?.username || (order as any).user?.username || '—';

  return (
    <div className="bg-white rounded-[24px] border border-slate-100 shadow-sm overflow-hidden hover:shadow-[0_8px_30px_rgb(0,0,0,0.04)] transition-all duration-300 mb-6 group">
      {/* Header */}
      <div className="p-6 md:px-8 md:py-6 flex flex-col md:flex-row md:items-center justify-between gap-6 border-b border-slate-50 relative">
        <div className="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-5">
          {/* Icon Box */}
          <div className={`shrink-0 w-14 h-14 rounded-[16px] flex items-center justify-center border shadow-sm transition-transform group-hover:scale-105 ${typeIconBg}`}>
            <TypeIcon className="w-6 h-6" />
          </div>

          <div className="flex flex-col gap-1.5">
            <div className="flex flex-wrap items-center gap-2.5">
              <h3 className="text-[20px] font-bold text-slate-800 tracking-tight">{order.code}</h3>
              <span className={`px-2.5 py-1 rounded-[8px] text-[10px] font-bold uppercase tracking-wider ${typeBadgeColors}`}>
                {isInbound ? 'NHẬP KHO' : 'XUẤT KHO'}
              </span>
              <span className={`px-2.5 py-1 rounded-[8px] text-[10px] font-bold uppercase tracking-wider ${statusObj.colors}`}>
                {statusObj.label}
              </span>
            </div>
            <div className="text-[13px] font-medium text-slate-500 flex items-center gap-2">
              <span>Người tạo: <span className="text-slate-700 font-bold">{creatorName}</span></span>
              <span className="text-slate-300">|</span>
              <span>Ngày tạo: {dateStr}</span>
            </div>
          </div>
        </div>

        {/* Actions Box */}
        <div className="flex items-center gap-3">
          <button
            title="Chỉnh sửa phiểu"
            onClick={() => onEdit(order.id)}
            className="p-2.5 text-slate-400 hover:text-slate-700 bg-white hover:bg-slate-50 border border-slate-200 rounded-[12px] transition-colors shadow-sm"
          >
            <Edit2 className="w-4 h-4" />
          </button>
          <button
            title="Xóa phiểu"
            onClick={() => onDelete(order.id)}
            className="p-2.5 text-slate-400 hover:text-red-600 bg-white hover:bg-red-50 border border-slate-200 rounded-[12px] transition-colors shadow-sm"
          >
            <Trash2 className="w-4 h-4" />
          </button>
          <button
            onClick={() => onView(order.id)}
            className={`px-5 py-2.5 text-sm font-bold rounded-[12px] shadow-sm transition-colors ${order.status === 'PENDING'
              ? 'bg-[#04147B] hover:bg-[#030e57] text-white'
              : 'bg-white border border-slate-200 text-[#04147B] hover:bg-slate-50'
              }`}
          >
            {order.status === 'PENDING' ? 'Bắt Đầu Quét' : 'Xem Chi Tiết'}
          </button>
        </div>
      </div>

      {/* Body: 2 Columns */}
      <div className="p-6 md:p-8 flex flex-col xl:flex-row gap-8 xl:gap-12">

        {/* Left Column: Progress */}
        <div className="flex-1 max-w-[400px] xl:border-r border-slate-100 xl:pr-12 flex flex-col justify-center">
          <div className="flex justify-between items-end mb-4">
            <h4 className="text-[14px] font-bold text-slate-600 tracking-wide uppercase">Tiến độ quét RFID</h4>
            <div className={`font-mono font-bold text-[15px] ${isInbound ? 'text-[#04147B]' : 'text-emerald-500'}`}>
              {prog.scan} <span className="text-slate-400">/ {prog.req}</span>
              <span className="text-xs ml-1.5 font-bold text-[#04147B]">({prog.pct}%)</span>
            </div>
          </div>

          <div className="w-full h-3.5 bg-slate-100 rounded-full overflow-hidden mb-5">
            <div
              className={`h-full rounded-full transition-all duration-700 ease-out ${statusObj.bar}`}
              style={{ width: `${Math.min(prog.pct, 100)}%` }}
            />
          </div>

          <div className="flex items-center gap-2 px-3 py-1.5 bg-slate-100 rounded-lg text-slate-600 text-sm font-medium mb-4">
            <span className="font-bold">By:</span> {creatorName}
          </div>

          <div className="flex items-center gap-6 text-[13px] font-medium text-slate-500">
            <div className="flex items-center gap-2">
              <span className={`w-2.5 h-2.5 rounded-full ${order.status === 'COMPLETED' || prog.scan > 0 ? 'bg-emerald-500' : 'bg-slate-300'}`}></span>
              <span className="text-slate-600 font-bold">{prog.scan}</span> Thành công
            </div>
            <div className="flex items-center gap-2">
              <span className={`w-2.5 h-2.5 rounded-full ${prog.pending > 0 ? 'bg-amber-400' : 'bg-slate-300'}`}></span>
              <span className="text-slate-600 font-bold">{prog.pending}</span> Đang chờ
            </div>
          </div>
        </div>

        {/* Right Column: Mini Table */}
        <div className="flex-[1.5] bg-slate-50/80 rounded-[20px] border border-slate-100 overflow-hidden">
          <div className="overflow-x-auto">
            <table className="w-full text-[13px] min-w-[500px]">
              <thead>
                <tr className="border-b border-slate-100">
                  <th className="px-6 py-4 text-left font-bold text-slate-400 tracking-wider text-[11px] uppercase">SẢN PHẨM</th>
                  <th className="px-6 py-4 text-center font-bold text-slate-400 tracking-wider text-[11px] uppercase w-28">YÊU CẦU</th>
                  <th className="px-6 py-4 text-center font-bold text-slate-400 tracking-wider text-[11px] uppercase w-28">THỰC TẾ</th>
                </tr>
              </thead>
              <tbody className="divide-y divide-slate-100">
                {order.items.slice(0, 3).map((item) => (
                  <tr key={item.id} className="hover:bg-white transition-colors">
                    <td className="px-6 py-4">
                      <div className="font-bold text-slate-700">{item.product.name}</div>
                      <div className="text-[11px] text-slate-400 mt-1 font-mono uppercase tracking-wider">SKU: {item.product.sku}</div>
                    </td>
                    <td className="px-6 py-4 text-center font-bold text-slate-500 font-mono">
                      {item.quantity}
                    </td>
                    <td className="px-6 py-4 text-center">
                      <span className={`font-mono font-bold ${item.scannedQuantity === item.quantity
                        ? 'text-emerald-500'
                        : (item.scannedQuantity > 0 ? 'text-[#04147B]' : 'text-[#04147B]')
                        }`}>
                        {item.scannedQuantity}
                      </span>
                    </td>
                  </tr>
                ))}
                {order.items.length > 3 && (
                  <tr className="hover:bg-white transition-colors">
                    <td colSpan={3} className="px-6 py-3 text-center text-xs font-bold text-[#04147B]/60 cursor-pointer hover:text-[#04147B] transition-colors">
                      + Xem thêm {order.items.length - 3} chi tiết sản phẩm...
                    </td>
                  </tr>
                )}
                {order.items.length === 0 && (
                  <tr>
                    <td colSpan={3} className="px-6 py-8 text-center text-xs font-medium text-slate-400">
                      Phiếu này chưa có chi tiết sản phẩm nào.
                    </td>
                  </tr>
                )}
              </tbody>
            </table>
          </div>
        </div>

      </div>
    </div>
  );
};
